{
  "name": "omnichannel-ai-workspace",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "backfill-embeddings": "tsx scripts/backfill-knowledge-embeddings.ts",
    "sync-obsidian": "tsx scripts/sync-obsidian-vault.ts",
    "playwright-cli": "tsx scripts/playwright-cli.ts",
    "pw": "tsx scripts/playwright-cli.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push --linked",
    "db:pull": "supabase db pull",
    "db:diff": "supabase db diff -f",
    "db:lint": "supabase db lint",
    "migration:new": "supabase migration new",
    "migration:list": "supabase migration list --local",
    "types:gen": "supabase gen types typescript --local > src/db/database.types.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
