# Anthropic
ANTHROPIC_API_KEY=               # Your Anthropic API key
CLAUDE_MODEL=claude-haiku-4-5    # Default. Or claude-sonnet-4-6 for complex quotes.

# Supabase
SUPABASE_URL=                    # Your Supabase project URL
SUPABASE_SERVICE_KEY=            # Service role key (not anon key)

# Telegram
TELEGRAM_BOT_TOKEN=              # From BotFather

# n8n
N8N_BASE_URL=https://freshbros2.app.n8n.cloud/webhook

# Inventory sync (published Google Sheet HTML)
INVENTORY_SHEET_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vQMHTL3xCIALEJmM5NWMLWPKMAwbphaNP5t14KZbBWTJFfVBOrXFkZcCVtukvaFQ2vKJvH7U_9tAx2G/pubhtml

# Server
PORT=3000
NODE_ENV=development

# Security
WEBHOOK_SECRET=                  # Random string, used to verify Telegram webhook calls
ADMIN_TOKEN=                     # Required in production. Set x-admin-token header for /admin and /admin/api

# Obsidian vault sync (optional) — See docs/OBSIDIAN-INTEGRATION.md
# OBSIDIAN_VAULT_PATH=           # Path to your Obsidian vault
# OBSIDIAN_TENANT_SLUG=default
# OBSIDIAN_KNOWLEDGE_FOLDER=AI Knowledge
# OBSIDIAN_CONTENT_FOLDER=Business
